    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_updated_date">Updated: 02.04.2026</string>
    <string name="privacy_section_1_title">1. What data we store</string>
    <string name="privacy_section_1_content">We store profile data, habits, completion marks, and settings. In guest mode, data is stored only locally on your device.</string>
    <string name="privacy_section_2_title">2. Sync and cloud</string>
    <string name="privacy_section_2_content">If you sign in with Google, data can sync with Firebase to restore after reinstalling or signing in on a new device.</string>
    <string name="privacy_section_3_title">3. Notifications</string>
    <string name="privacy_section_3_content">Reminders work only when Push notifications are enabled in settings. After disabling, new reminders are not scheduled and active ones are canceled.</string>
    <string name="privacy_section_4_title">4. Security</string>
    <string name="privacy_section_4_content">Data transfer to cloud services uses secure channels. We do not sell your personal data to third parties.</string>
    <string name="privacy_section_5_title">5. Storage and deletion</string>
    <string name="privacy_section_5_content">You can delete your account in settings. Guest mode local data can be cleared by uninstalling the app or clearing app data in Android settings.</string>
    <string name="privacy_section_6_title">6. Your rights</string>
    <string name="privacy_section_6_content">You can view, update, and delete your data at any time. By using the app, you agree to this privacy policy.</string>

